#!/usr/bin/env python3
"""AutoResearch assessment runner.

Assesses artifacts against test cases using either the Claude Agent SDK
(default) or a custom runner command, then grades with assertion functions.

Commands:
    autoresearch-runner assess --artifact P --test-case TC [--output FILE]
    autoresearch-runner batch-assess --variant name:path [--variant ...] [--track-baseline] [--promote-winner]
    autoresearch-runner promote <variant> [--cycle N]
    autoresearch-runner report --cycle N
    autoresearch-runner summarize <results-dir> [--output FILE]
    autoresearch-runner compare <result1.json> <result2.json> ...
"""

import asyncio
import importlib.util
import json
import os
import re
import shutil
import subprocess as _sp
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

AUTORESEARCH_DIR = ".autoresearch"
_VENV_DIR = os.path.join(AUTORESEARCH_DIR, ".venv")
CONFIG_FILE = f"{AUTORESEARCH_DIR}/config.json"
DEFAULT_ASSERTIONS = f"{AUTORESEARCH_DIR}/assertions.py"
RESULTS_DIR = f"{AUTORESEARCH_DIR}/results"
SCORES_FILE = f"{RESULTS_DIR}/scores.json"


# ---------------------------------------------------------------------------
# Venv bootstrap — installs claude-agent-sdk on first run
# ---------------------------------------------------------------------------

def _get_site_packages() -> str:
    return os.path.join(
        _VENV_DIR, "lib",
        f"python{sys.version_info.major}.{sys.version_info.minor}",
        "site-packages",
    )


def _ensure_venv():
    """Create a venv in .autoresearch/.venv and install the Agent SDK if needed."""
    py_version = f"{sys.version_info.major}.{sys.version_info.minor}"
    marker = os.path.join(_VENV_DIR, ".installed")
    site_pkgs = _get_site_packages()

    needs_setup = True
    if os.path.exists(marker):
        stored_version = Path(marker).read_text().strip()
        if stored_version == py_version and os.path.isdir(site_pkgs):
            needs_setup = False

    if not needs_setup:
        import site
        if site_pkgs not in sys.path:
            sys.path.insert(0, site_pkgs)
            site.addsitedir(site_pkgs)
        return

    if os.path.exists(_VENV_DIR):
        import shutil
        shutil.rmtree(_VENV_DIR)

    print("Setting up autoresearch environment...", flush=True)
    os.makedirs(AUTORESEARCH_DIR, exist_ok=True)
    venv_python = os.path.join(_VENV_DIR, "bin", "python")
    _sp.check_call(["uv", "venv", "-q", "--python", sys.executable, _VENV_DIR])
    _sp.check_call(["uv", "pip", "install", "-q", "-p", venv_python, "claude-agent-sdk"])

    import site
    sys.path.insert(0, site_pkgs)
    site.addsitedir(site_pkgs)

    Path(marker).write_text(py_version)
    print("Done.", flush=True)


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def load_config() -> dict:
    config_path = Path(CONFIG_FILE)
    if config_path.exists():
        return json.loads(config_path.read_text())
    return {}


def load_assertions(assertions_path: str):
    path = Path(assertions_path)
    if not path.exists():
        print(f"ERROR: Assertions file not found: {assertions_path}", file=sys.stderr)
        sys.exit(1)
    spec = importlib.util.spec_from_file_location("assertions", path)
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    if not hasattr(module, "ASSERTIONS"):
        print(f"ERROR: {assertions_path} must define an ASSERTIONS list", file=sys.stderr)
        sys.exit(1)
    return module.ASSERTIONS


def load_test_case(test_cases_path: str, test_case_id: str) -> dict:
    """Load a single test case by ID from a JSONL file."""
    for line in Path(test_cases_path).read_text().strip().split("\n"):
        case = json.loads(line)
        if case["id"] == test_case_id:
            return case
    print(f"ERROR: Test case '{test_case_id}' not found in {test_cases_path}", file=sys.stderr)
    sys.exit(1)


def load_all_test_cases(test_cases_path: str) -> list[dict]:
    """Load all test cases from a JSONL file."""
    cases = []
    for line in Path(test_cases_path).read_text().strip().split("\n"):
        if line.strip():
            cases.append(json.loads(line))
    return cases


# ---------------------------------------------------------------------------
# assess — get response (SDK or custom runner) + grade with assertions
# ---------------------------------------------------------------------------

def _run_sdk(artifact_path: str, case: dict, model: str) -> str:
    """Get a response via an isolated Claude Agent SDK call."""
    import asyncio

    _ensure_venv()
    from claude_agent_sdk import query, ClaudeAgentOptions, ResultMessage

    prompt = Path(artifact_path).read_text()

    async def get_response() -> str:
        result_text = ""
        async for message in query(
            prompt=case["input"],
            options=ClaudeAgentOptions(
                system_prompt=prompt,
                model=model,
                max_turns=1,
                permission_mode="dontAsk",
                tools=[],
                setting_sources=[],
                plugins=[],
            ),
        ):
            if isinstance(message, ResultMessage):
                if message.is_error:
                    raise RuntimeError(f"SDK error: {message.result}")
                result_text = message.result or ""
        return result_text

    return asyncio.run(get_response())


def _run_custom(runner_cmd: str, artifact_path: str, case: dict) -> str:
    """Get a response by running a custom command.

    The command receives context via environment variables:
        AUTORESEARCH_ARTIFACT  — path to the artifact being optimized
        AUTORESEARCH_TEST_ID   — test case ID
        AUTORESEARCH_TEST_INPUT — test case input text

    stdout is captured as the response text.
    """
    env = {**os.environ,
           "AUTORESEARCH_ARTIFACT": artifact_path,
           "AUTORESEARCH_TEST_ID": case["id"],
           "AUTORESEARCH_TEST_INPUT": case["input"]}
    proc = _sp.run(runner_cmd, shell=True, capture_output=True, text=True, env=env)
    if proc.returncode != 0:
        stderr = proc.stderr.strip()
        raise RuntimeError(f"Runner exited {proc.returncode}: {stderr}")
    return proc.stdout


def cmd_assess(artifact_path: str, test_case_id: str, assertions_path: str,
               test_cases_path: str, output_path: str | None, model: str,
               runner_cmd: str | None):
    """Assess a single test case: get response, then grade with assertions."""
    case = load_test_case(test_cases_path, test_case_id)
    assertions = load_assertions(assertions_path)

    mode = "custom" if runner_cmd else "sdk"
    print(f"Assessing: {test_case_id} (artifact: {artifact_path}, mode: {mode})", flush=True)
    start = time.time()

    try:
        if runner_cmd:
            output = _run_custom(runner_cmd, artifact_path, case)
        else:
            output = _run_sdk(artifact_path, case, model)
        elapsed = time.time() - start

        # --- Run assertions ---
        assertion_results = {}
        for fn in assertions:
            try:
                assertion_results[fn.__name__] = fn(output)
            except Exception as e:
                assertion_results[fn.__name__] = False
                print(f"  WARNING: {fn.__name__} raised {e}", file=sys.stderr)

        case_passed = all(assertion_results.values())
        failed = [k for k, v in assertion_results.items() if not v]

        result = {
            "id": test_case_id,
            "category": case.get("category", "unknown"),
            "passed": case_passed,
            "assertions": assertion_results,
            "failed": failed,
            "output": output,
            "output_length": len(output),
            "elapsed_seconds": round(elapsed, 1),
        }

        status = "PASS" if case_passed else f"FAIL [{', '.join(failed)}]"
        print(f"  {test_case_id}: {status} ({elapsed:.1f}s)")

    except Exception as e:
        elapsed = time.time() - start
        print(f"  {test_case_id}: ERROR ({elapsed:.1f}s): {e}", file=sys.stderr)
        result = {
            "id": test_case_id,
            "category": case.get("category", "unknown"),
            "passed": False,
            "assertions": {},
            "failed": ["error"],
            "error": str(e),
            "output": "",
            "output_length": 0,
            "elapsed_seconds": round(elapsed, 1),
        }

    # --- Save result ---
    if output_path:
        Path(output_path).parent.mkdir(parents=True, exist_ok=True)
        Path(output_path).write_text(json.dumps(result, indent=2))
        print(f"  Result: {output_path}")

    # Also print summary to stdout for the parent agent
    print(json.dumps({"id": test_case_id, "passed": result["passed"], "failed": result["failed"]}))


# ---------------------------------------------------------------------------
# summarize — aggregate per-test-case results into a run summary
# ---------------------------------------------------------------------------

def cmd_summarize(results_dir: str, output_path: str | None, prompt_label: str | None,
                   track_score: bool = False, model: str | None = None):
    """Aggregate individual test case results into a run summary."""
    results_path = Path(results_dir)
    if not results_path.is_dir():
        print(f"ERROR: Not a directory: {results_dir}", file=sys.stderr)
        sys.exit(1)

    result_files = sorted(results_path.glob("*.json"))
    if not result_files:
        print(f"ERROR: No .json files in {results_dir}", file=sys.stderr)
        sys.exit(1)

    results = []
    passed = 0
    skipped = 0
    all_assertion_names = set()

    print(f"Summarizing results from: {results_dir}")
    print("-" * 60)

    for f in result_files:
        r = json.loads(f.read_text())
        if "id" not in r or "assertions" not in r:
            skipped += 1
            continue
        results.append(r)
        all_assertion_names.update(r.get("assertions", {}).keys())
        if r["passed"]:
            passed += 1
            print(f"  {r['id']}: PASS")
        else:
            print(f"  {r['id']}: FAIL [{', '.join(r.get('failed', []))}]")

    if skipped:
        print(f"  (skipped {skipped} non-result file(s))")

    total = len(results)
    if total == 0:
        print(f"ERROR: No valid test-case results in {results_dir}", file=sys.stderr)
        sys.exit(1)

    pass_rate = passed / total if total > 0 else 0

    # Assertion-level pass rates
    assertion_rates = {}
    for name in sorted(all_assertion_names):
        assertion_passed = sum(1 for r in results if r.get("assertions", {}).get(name, False))
        assertion_rates[name] = round(assertion_passed / total, 3) if total > 0 else 0

    # Category breakdown
    categories = {}
    for r in results:
        cat = r.get("category", "unknown")
        if cat not in categories:
            categories[cat] = {"passed": 0, "total": 0}
        categories[cat]["total"] += 1
        if r["passed"]:
            categories[cat]["passed"] += 1

    run_result = {
        "prompt": prompt_label or results_dir,
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "model": model,
        "pass_rate": round(pass_rate, 3),
        "passed": passed,
        "total": total,
        "assertion_pass_rates": assertion_rates,
        "category_breakdown": categories,
        "results": results,
    }

    # Print summary
    print("\n" + "=" * 60)
    print(f"PASS RATE: {passed}/{total} ({pass_rate:.1%})")
    print(f"\nAssertion breakdown:")
    for name, rate in assertion_rates.items():
        bar = "#" * int(rate * 20) + "." * (20 - int(rate * 20))
        print(f"  {name:40s} [{bar}] {rate:.0%}")

    print(f"\nCategory breakdown:")
    for cat, stats in sorted(categories.items()):
        status = "PASS" if stats["passed"] == stats["total"] else f"{stats['passed']}/{stats['total']}"
        print(f"  {cat:20s} {status}")
    print("=" * 60)

    # Save
    Path(RESULTS_DIR).mkdir(parents=True, exist_ok=True)
    dest = output_path or f"{RESULTS_DIR}/latest_run.json"
    Path(dest).write_text(json.dumps(run_result, indent=2))
    print(f"\nResults written to: {dest}")

    # Append to scores history (only when explicitly requested, e.g. on promotion)
    if track_score:
        scores_path = Path(SCORES_FILE)
        scores = json.loads(scores_path.read_text()) if scores_path.exists() else []
        scores.append({
            "prompt": prompt_label or results_dir,
            "timestamp": run_result["timestamp"],
            "model": model,
            "pass_rate": run_result["pass_rate"],
            "assertion_pass_rates": assertion_rates,
        })
        scores_path.write_text(json.dumps(scores, indent=2))


# ---------------------------------------------------------------------------
# compare — side-by-side comparison of run summaries
# ---------------------------------------------------------------------------

def cmd_compare(*result_files: str):
    """Compare results from multiple summary JSON files."""
    rates = []
    for path in result_files:
        data = json.loads(Path(path).read_text())
        name = Path(path).stem
        rates.append((name, data["pass_rate"]))

    print("\n" + "=" * 60)
    print("COMPARISON SUMMARY")
    print("=" * 60)
    rates.sort(key=lambda x: x[1], reverse=True)
    top_rate = rates[0][1]
    tied_at_top = sum(1 for _, r in rates if r == top_rate)
    for name, rate in rates:
        if rate == top_rate and tied_at_top == 1:
            marker = " <-- BEST"
        elif rate == top_rate and tied_at_top > 1:
            marker = " <-- TIED"
        else:
            marker = ""
        print(f"  {name:30s} {rate:.1%}{marker}")

    best_name, best_rate = rates[0]
    if tied_at_top > 1:
        tied_names = [n for n, r in rates if r == top_rate]
        print(f"\nTied at {best_rate:.1%}: {', '.join(tied_names)}")
    elif len(rates) > 1 and best_rate > rates[-1][1]:
        print(f"\nBest: '{best_name}' at {best_rate:.1%}")
    print("=" * 60)


# ---------------------------------------------------------------------------
# batch-assess — assess all test cases for multiple variants in one process
# ---------------------------------------------------------------------------

_MAX_PARALLEL = 10  # limit concurrent assessments to avoid overwhelming APIs


async def _assess_one_async(variant_name: str, artifact_path: str, case: dict,
                            assertions: list, model: str, runner_cmd: str | None,
                            sem: asyncio.Semaphore) -> dict:
    """Assess a single test case asynchronously."""
    async with sem:
        start = time.time()
        try:
            if runner_cmd:
                env = {**os.environ,
                       "AUTORESEARCH_ARTIFACT": artifact_path,
                       "AUTORESEARCH_TEST_ID": case["id"],
                       "AUTORESEARCH_TEST_INPUT": case["input"]}
                proc = await asyncio.create_subprocess_shell(
                    runner_cmd,
                    stdout=asyncio.subprocess.PIPE,
                    stderr=asyncio.subprocess.PIPE,
                    env=env,
                )
                stdout, stderr = await proc.communicate()
                if proc.returncode != 0:
                    raise RuntimeError(
                        f"Runner exited {proc.returncode}: {stderr.decode().strip()}")
                output = stdout.decode()
            else:
                from claude_agent_sdk import query, ClaudeAgentOptions, ResultMessage
                prompt = Path(artifact_path).read_text()
                output = ""
                async for message in query(
                    prompt=case["input"],
                    options=ClaudeAgentOptions(
                        system_prompt=prompt,
                        model=model,
                        max_turns=1,
                        permission_mode="dontAsk",
                        tools=[],
                        setting_sources=[],
                        plugins=[],
                    ),
                ):
                    if isinstance(message, ResultMessage):
                        if message.is_error:
                            raise RuntimeError(f"SDK error: {message.result}")
                        output = message.result or ""

            elapsed = time.time() - start

            assertion_results = {}
            for fn in assertions:
                try:
                    assertion_results[fn.__name__] = fn(output)
                except Exception as e:
                    assertion_results[fn.__name__] = False
                    print(f"  WARNING: {fn.__name__} raised {e}", file=sys.stderr)

            case_passed = all(assertion_results.values())
            failed = [k for k, v in assertion_results.items() if not v]

            status = "PASS" if case_passed else f"FAIL [{', '.join(failed)}]"
            print(f"  {variant_name}/{case['id']}: {status} ({elapsed:.1f}s)", flush=True)

            return {
                "id": case["id"],
                "category": case.get("category", "unknown"),
                "passed": case_passed,
                "assertions": assertion_results,
                "failed": failed,
                "output": output,
                "output_length": len(output),
                "elapsed_seconds": round(elapsed, 1),
            }
        except Exception as e:
            elapsed = time.time() - start
            print(f"  {variant_name}/{case['id']}: ERROR ({elapsed:.1f}s): {e}",
                  file=sys.stderr, flush=True)
            return {
                "id": case["id"],
                "category": case.get("category", "unknown"),
                "passed": False,
                "assertions": {},
                "failed": ["error"],
                "error": str(e),
                "output": "",
                "output_length": 0,
                "elapsed_seconds": round(elapsed, 1),
            }


def _summarize_results(variant_name: str, results: list[dict],
                       track_score: bool = False,
                       model: str | None = None) -> dict:
    """Summarize a list of result dicts into a run summary. Returns the summary."""
    passed = sum(1 for r in results if r["passed"])
    total = len(results)
    pass_rate = passed / total if total > 0 else 0

    all_assertion_names = set()
    for r in results:
        all_assertion_names.update(r.get("assertions", {}).keys())

    assertion_rates = {}
    for name in sorted(all_assertion_names):
        ap = sum(1 for r in results if r.get("assertions", {}).get(name, False))
        assertion_rates[name] = round(ap / total, 3) if total > 0 else 0

    categories = {}
    for r in results:
        cat = r.get("category", "unknown")
        if cat not in categories:
            categories[cat] = {"passed": 0, "total": 0}
        categories[cat]["total"] += 1
        if r["passed"]:
            categories[cat]["passed"] += 1

    summary = {
        "prompt": variant_name,
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "model": model,
        "pass_rate": round(pass_rate, 3),
        "passed": passed,
        "total": total,
        "assertion_pass_rates": assertion_rates,
        "category_breakdown": categories,
        "results": results,
    }

    summary_path = Path(RESULTS_DIR) / f"summary_{variant_name}.json"
    summary_path.parent.mkdir(parents=True, exist_ok=True)
    summary_path.write_text(json.dumps(summary, indent=2))

    if track_score:
        scores_path = Path(SCORES_FILE)
        scores = json.loads(scores_path.read_text()) if scores_path.exists() else []
        scores.append({
            "prompt": variant_name,
            "timestamp": summary["timestamp"],
            "model": model,
            "pass_rate": summary["pass_rate"],
            "assertion_pass_rates": assertion_rates,
        })
        scores_path.write_text(json.dumps(scores, indent=2))

    return summary


def cmd_batch_assess(variants: list[tuple[str, str]], assertions_path: str,
                     test_cases_path: str, model: str, runner_cmd: str | None,
                     parallel: bool, track_baseline: bool = False,
                     promote_winner: bool = False):
    """Assess all test cases for multiple variants, summarize, and compare.

    variants: list of (name, artifact_path) tuples
    If promote_winner: auto-call promote on the winning variant at the end.
    """
    test_cases = load_all_test_cases(test_cases_path)
    assertions = load_assertions(assertions_path)

    if not runner_cmd:
        _ensure_venv()

    print(f"Batch assessment: {len(variants)} variant(s) x {len(test_cases)} test cases")
    mode = "custom runner" if runner_cmd else f"sdk ({model})"
    print(f"Mode: {mode}")
    print(f"Parallelism: {'enabled' if parallel else 'disabled'}")
    print("=" * 60)

    sem = asyncio.Semaphore(_MAX_PARALLEL)
    all_summaries = []

    async def run():
        for variant_name, artifact_path in variants:
            print(f"\n--- {variant_name}: {artifact_path} ---", flush=True)

            if parallel:
                results = list(await asyncio.gather(*[
                    _assess_one_async(variant_name, artifact_path, case,
                                      assertions, model, runner_cmd, sem)
                    for case in test_cases
                ]))
            else:
                results = []
                for case in test_cases:
                    result = await _assess_one_async(
                        variant_name, artifact_path, case,
                        assertions, model, runner_cmd, sem)
                    results.append(result)

            # Write per-test-case results
            variant_dir = Path(RESULTS_DIR) / variant_name
            variant_dir.mkdir(parents=True, exist_ok=True)
            for result in results:
                result_path = variant_dir / f"{result['id']}.json"
                result_path.write_text(json.dumps(result, indent=2))

            # Summarize — model is only meaningful in SDK mode
            should_track = track_baseline and variant_name == "current"
            effective_model = None if runner_cmd else model
            summary = _summarize_results(variant_name, results,
                                         track_score=should_track,
                                         model=effective_model)
            all_summaries.append((variant_name, summary["pass_rate"]))

            print(f"  Summary: {summary['passed']}/{summary['total']}"
                  f" ({summary['pass_rate']:.1%})", flush=True)

    asyncio.run(run())

    # Print formatted report table
    if all_summaries:
        # Reload summaries for assertion-level detail
        variant_data = []
        assertion_names = set()
        for vname, _ in all_summaries:
            spath = Path(RESULTS_DIR) / f"summary_{vname}.json"
            if spath.exists():
                s = json.loads(spath.read_text())
                variant_data.append((vname, s))
                assertion_names.update(s.get("assertion_pass_rates", {}).keys())
        assertion_names = sorted(assertion_names)

        current_rate = next((s["pass_rate"] for n, s in variant_data if n == "current"), None)

        # Build rows
        columns = ["Variant", "Pass Rate"] + assertion_names + ["vs Current"]
        rows = []
        best_name, best_rate = "current", current_rate or 0

        for vname, summary in variant_data:
            rate = summary["pass_rate"]
            a_rates = summary.get("assertion_pass_rates", {})

            if vname == "current":
                delta = "—"
            else:
                d = (rate - (current_rate or 0)) * 100
                delta = f"+{d:.0f}%" if d >= 0 else f"{d:.0f}%"
                if rate > best_rate:
                    best_name, best_rate = vname, rate

            row = [vname, f"{rate:.0%}"]
            row += [f"{a_rates.get(a, 0):.0%}" for a in assertion_names]
            row += [delta]
            rows.append(row)

        # Compute column widths and print
        widths = [len(c) for c in columns]
        for row in rows:
            for i, cell in enumerate(row):
                widths[i] = max(widths[i], len(cell))

        def fmt_row(cells):
            return "| " + " | ".join(c.ljust(widths[i]) for i, c in enumerate(cells)) + " |"

        def fmt_sep():
            return "|" + "|".join("-" * (w + 2) for w in widths) + "|"

        print("\n" + fmt_row(columns))
        print(fmt_sep())
        for row in rows:
            print(fmt_row(row))

        if best_name != "current":
            print(f"\nWinner: {best_name} ({best_rate:.0%})")
            if promote_winner:
                print()
                _promote_winner(best_name, model=model)
        elif current_rate is not None:
            print(f"\nNo improvement. Current: {current_rate:.0%}")

        # Trajectory
        scores_path = Path(SCORES_FILE)
        if scores_path.exists():
            scores = json.loads(scores_path.read_text())
            if scores:
                trajectory = " → ".join(f"{s['pass_rate']:.0%}" for s in scores)
                print(f"Trajectory: {trajectory}")


# ---------------------------------------------------------------------------
# promote — apply a winning variant to current, archive prior state, track score
# ---------------------------------------------------------------------------

def _promote_winner(variant_name: str, cycle: int | None = None,
                    model: str | None = None) -> bool:
    """Apply variant_name as the new current, archive prior state, record score.

    Returns True on success, False if the variant summary is missing.
    Behavior depends on mode:
      - Prompt mode: copies candidates/<variant>.txt -> current.txt
      - Custom runner mode: archives current artifact, assumes caller has
        already applied the change to the artifact file.
    In both modes: appends the variant's pass_rate to scores.json with a
    'promoted_from' field.
    """
    config = load_config()
    summary_path = Path(RESULTS_DIR) / f"summary_{variant_name}.json"
    if not summary_path.exists():
        print(f"ERROR: {summary_path} not found", file=sys.stderr)
        return False

    summary = json.loads(summary_path.read_text())
    pass_rate = summary["pass_rate"]
    rate_label = f"{int(round(pass_rate * 100))}"

    # Infer cycle from variant name if not given (e.g., "v1a" -> 1)
    if cycle is None:
        m = re.match(r"v(\d+)", variant_name)
        if m:
            cycle = int(m.group(1))

    is_prompt_mode = not config.get("runner")

    if is_prompt_mode:
        current_path = Path(config.get("artifact")
                            or ".autoresearch/prompts/current.txt")
        candidate = Path(f".autoresearch/prompts/candidates/{variant_name}.txt")
        if not candidate.exists():
            print(f"ERROR: candidate {candidate} not found", file=sys.stderr)
            return False
        # Archive prior current
        history_dir = Path(".autoresearch/prompts/history")
        history_dir.mkdir(parents=True, exist_ok=True)
        if current_path.exists() and cycle is not None:
            archive = history_dir / f"v{cycle}_score{rate_label}.txt"
            shutil.copy(current_path, archive)
        # Apply winner
        shutil.copy(candidate, current_path)
        print(f"Promoted {variant_name}: {current_path} <- {candidate}")
    else:
        # Custom runner mode: archive current artifact state under history/
        artifact = Path(config.get("artifact", "processor.py"))
        if cycle is not None and artifact.exists():
            history_dir = Path(f".autoresearch/history/v{cycle}_score{rate_label}")
            history_dir.mkdir(parents=True, exist_ok=True)
            if artifact.is_file():
                shutil.copy(artifact, history_dir / artifact.name)
            elif artifact.is_dir():
                shutil.copytree(artifact, history_dir / artifact.name,
                                dirs_exist_ok=True)
        print(f"Promoted {variant_name}: {pass_rate:.0%} "
              f"(assume {artifact} already in winning state)")

    # Record in scores.json — always (this is the key win of this command)
    effective_model = None if config.get("runner") else (
        model or config.get("model", "sonnet"))
    scores_path = Path(SCORES_FILE)
    scores = json.loads(scores_path.read_text()) if scores_path.exists() else []
    scores.append({
        "prompt": "current",
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "model": effective_model,
        "pass_rate": pass_rate,
        "assertion_pass_rates": summary.get("assertion_pass_rates", {}),
        "promoted_from": variant_name,
    })
    scores_path.write_text(json.dumps(scores, indent=2))
    print(f"Recorded {pass_rate:.0%} in {SCORES_FILE} (cycle {cycle})")

    # Sync summary_current.json to reflect the new current (= the winning variant).
    # Without this, summary_current.json reflects the last batch-assess of "current"
    # before promotion — which is stale after the artifact is swapped.
    current_summary = dict(summary)
    current_summary["prompt"] = "current"
    current_summary["timestamp"] = datetime.now(timezone.utc).isoformat()
    current_summary["model"] = effective_model
    current_summary["promoted_from"] = variant_name
    (Path(RESULTS_DIR) / "summary_current.json").write_text(
        json.dumps(current_summary, indent=2))
    return True


def cmd_promote(variant_name: str, cycle: int | None = None,
                model: str | None = None):
    """CLI entry point for promote."""
    ok = _promote_winner(variant_name, cycle, model)
    sys.exit(0 if ok else 1)


# ---------------------------------------------------------------------------
# report — deterministic formatted cycle report from summary JSONs
# ---------------------------------------------------------------------------

def cmd_report(cycle: int):
    """Output a formatted markdown report for a specific cycle.

    Reads summary_current.json and summary_v{cycle}{a,b,c,...}.json,
    plus scores.json for the trajectory. Outputs a ready-to-display
    table with per-assertion pass rates and aligned columns.
    """
    current_file = Path(RESULTS_DIR) / "summary_current.json"
    if not current_file.exists():
        print(f"ERROR: {current_file} not found", file=sys.stderr)
        sys.exit(1)

    current = json.loads(current_file.read_text())
    current_rate = current["pass_rate"]
    assertion_names = sorted(current.get("assertion_pass_rates", {}).keys())

    # Collect variants for this cycle
    variants = [("current", current)]
    for suffix in "abcde":
        vfile = Path(RESULTS_DIR) / f"summary_v{cycle}{suffix}.json"
        if vfile.exists():
            variants.append((f"v{cycle}{suffix}", json.loads(vfile.read_text())))

    if len(variants) < 2:
        print(f"No candidate summaries found for cycle {cycle}", file=sys.stderr)
        sys.exit(1)

    # Build rows first so we can compute column widths
    columns = ["Variant", "Pass Rate"] + assertion_names + ["vs Current"]
    rows = []
    best_name, best_rate = "current", current_rate

    for name, summary in variants:
        rate = summary["pass_rate"]
        a_rates = summary.get("assertion_pass_rates", {})

        if name == "current":
            delta = "—"
        else:
            d = (rate - current_rate) * 100
            delta = f"+{d:.0f}%" if d >= 0 else f"{d:.0f}%"
            if rate > best_rate:
                best_name, best_rate = name, rate

        row = [name, f"{rate:.0%}"]
        row += [f"{a_rates.get(a, 0):.0%}" for a in assertion_names]
        row += [delta]
        rows.append(row)

    # Compute column widths
    widths = [len(c) for c in columns]
    for row in rows:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], len(cell))

    def fmt_row(cells):
        return "| " + " | ".join(c.ljust(widths[i]) for i, c in enumerate(cells)) + " |"

    def fmt_sep():
        return "|" + "|".join("-" * (w + 2) for w in widths) + "|"

    # Print report
    print(f"## Cycle {cycle} Results\n")
    print(fmt_row(columns))
    print(fmt_sep())
    for row in rows:
        print(fmt_row(row))

    # Winner / no improvement
    print()
    if best_name != "current":
        print(f"Winner: {best_name} ({best_rate:.0%})")
    else:
        print(f"No improvement. Current remains at {current_rate:.0%}.")

    # Trajectory from scores.json
    scores_path = Path(SCORES_FILE)
    if scores_path.exists():
        scores = json.loads(scores_path.read_text())
        if scores:
            trajectory = " → ".join(f"{s['pass_rate']:.0%}" for s in scores)
            print(f"Trajectory: {trajectory}")


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    command = sys.argv[1]
    config = load_config()
    assertions_path = config.get("assertions", DEFAULT_ASSERTIONS)
    test_cases_path = config.get("test_cases", f"{AUTORESEARCH_DIR}/test_cases.jsonl")

    if command == "assess":
        artifact_path = None
        test_case_id = None
        output_path = None
        model = config.get("model", "sonnet")
        runner_cmd = config.get("runner")
        i = 2
        while i < len(sys.argv):
            if sys.argv[i] in ("--prompt", "--artifact"):
                artifact_path = sys.argv[i + 1]; i += 2
            elif sys.argv[i] == "--test-case":
                test_case_id = sys.argv[i + 1]; i += 2
            elif sys.argv[i] == "--output":
                output_path = sys.argv[i + 1]; i += 2
            elif sys.argv[i] == "--model":
                model = sys.argv[i + 1]; i += 2
            elif sys.argv[i] == "--runner":
                runner_cmd = sys.argv[i + 1]; i += 2
            elif sys.argv[i] == "--assertions":
                assertions_path = sys.argv[i + 1]; i += 2
            elif sys.argv[i] == "--test-cases":
                test_cases_path = sys.argv[i + 1]; i += 2
            else:
                print(f"Unknown flag: {sys.argv[i]}", file=sys.stderr)
                sys.exit(1)

        if not artifact_path:
            # Fall back to config
            artifact_path = config.get("artifact") or config.get("prompt")
        if not artifact_path or not test_case_id:
            print("Usage: autoresearch-runner assess --artifact <file> --test-case <id> [--output <file>]", file=sys.stderr)
            sys.exit(1)

        cmd_assess(artifact_path, test_case_id, assertions_path, test_cases_path, output_path, model, runner_cmd)

    elif command == "summarize":
        if len(sys.argv) < 3:
            print("Usage: autoresearch-runner summarize <results-dir> [--output <file>] [--label <name>] [--model <name>]", file=sys.stderr)
            sys.exit(1)
        results_dir = sys.argv[2]
        output_path = None
        label = None
        track_score = False
        # Model is only meaningful in SDK mode (no runner configured)
        model = None if config.get("runner") else config.get("model", "sonnet")
        i = 3
        while i < len(sys.argv):
            if sys.argv[i] == "--output":
                output_path = sys.argv[i + 1]; i += 2
            elif sys.argv[i] == "--label":
                label = sys.argv[i + 1]; i += 2
            elif sys.argv[i] == "--track-score":
                track_score = True; i += 1
            elif sys.argv[i] == "--model":
                model = sys.argv[i + 1]; i += 2
            else:
                print(f"Unknown flag: {sys.argv[i]}", file=sys.stderr)
                sys.exit(1)
        cmd_summarize(results_dir, output_path, label, track_score, model)

    elif command == "batch-assess":
        variants = []
        track_baseline = False
        promote_winner = False
        model = config.get("model", "sonnet")
        runner_cmd = config.get("runner")
        # Default: parallel for SDK mode, sequential for custom runner
        parallel = config.get("parallel", runner_cmd is None)
        i = 2
        while i < len(sys.argv):
            if sys.argv[i] == "--variant":
                # Format: name:artifact_path
                parts = sys.argv[i + 1].split(":", 1)
                if len(parts) != 2:
                    print(f"ERROR: --variant must be name:path, got '{sys.argv[i + 1]}'",
                          file=sys.stderr)
                    sys.exit(1)
                variants.append((parts[0], parts[1]))
                i += 2
            elif sys.argv[i] == "--track-baseline":
                track_baseline = True; i += 1
            elif sys.argv[i] == "--promote-winner":
                promote_winner = True; i += 1
            elif sys.argv[i] == "--model":
                model = sys.argv[i + 1]; i += 2
            elif sys.argv[i] == "--runner":
                runner_cmd = sys.argv[i + 1]; i += 2
            elif sys.argv[i] == "--assertions":
                assertions_path = sys.argv[i + 1]; i += 2
            elif sys.argv[i] == "--test-cases":
                test_cases_path = sys.argv[i + 1]; i += 2
            elif sys.argv[i] == "--parallel":
                parallel = True; i += 1
            elif sys.argv[i] == "--sequential":
                parallel = False; i += 1
            else:
                print(f"Unknown flag: {sys.argv[i]}", file=sys.stderr)
                sys.exit(1)

        if not variants:
            print("Usage: autoresearch-runner batch-assess --variant name:path "
                  "[--variant name:path ...] [--track-baseline] [--promote-winner]",
                  file=sys.stderr)
            sys.exit(1)

        cmd_batch_assess(variants, assertions_path, test_cases_path,
                         model, runner_cmd, parallel, track_baseline,
                         promote_winner)

    elif command == "promote":
        if len(sys.argv) < 3:
            print("Usage: autoresearch-runner promote <variant> [--cycle N] [--model <name>]",
                  file=sys.stderr)
            sys.exit(1)
        variant = sys.argv[2]
        cycle = None
        model = None
        i = 3
        while i < len(sys.argv):
            if sys.argv[i] == "--cycle":
                cycle = int(sys.argv[i + 1]); i += 2
            elif sys.argv[i] == "--model":
                model = sys.argv[i + 1]; i += 2
            else:
                print(f"Unknown flag: {sys.argv[i]}", file=sys.stderr)
                sys.exit(1)
        cmd_promote(variant, cycle, model)

    elif command == "report":
        cycle = None
        i = 2
        while i < len(sys.argv):
            if sys.argv[i] == "--cycle":
                cycle = int(sys.argv[i + 1]); i += 2
            else:
                print(f"Unknown flag: {sys.argv[i]}", file=sys.stderr)
                sys.exit(1)
        if cycle is None:
            print("Usage: autoresearch-runner report --cycle N", file=sys.stderr)
            sys.exit(1)
        cmd_report(cycle)

    elif command == "compare":
        if len(sys.argv) < 4:
            print("Usage: autoresearch-runner compare <result1.json> <result2.json> ...", file=sys.stderr)
            sys.exit(1)
        cmd_compare(*sys.argv[2:])

    else:
        print(f"Unknown command: {command}", file=sys.stderr)
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
